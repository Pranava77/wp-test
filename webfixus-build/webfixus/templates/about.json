          {
            "id": "1a2b02f",
            "elType": "widget",
            "widgetType": "html",
            "settings": {
              "html": "<div class=\"wfx-grid wfx-grid--4\"><div class=\"wfx-card\"><div class=\"wfx-step__num wfx-step__num--blue\">01</div><div class=\"wfx-step__title\">Brief</div><div class=\"wfx-step__text\">We talk. I learn the goal, the audience and the deadline.</div></div><div class=\"wfx-card\"><div class=\"wfx-step__num wfx-step__num--orange\">02</div><div class=\"wfx-step__title\">Sketch</div><div class=\"wfx-step__text\">2&ndash;3 rough directions. We pick one before any polish.</div></div><div class=\"wfx-card\"><div class=\"wfx-step__num wfx-step__num--green\">03</div><div class=\"wfx-step__title\">Draw</div><div class=\"wfx-step__text\">Final art, hand-drawn, with one round of revisions.</div></div><div class=\"wfx-card\"><div class=\"wfx-step__num wfx-step__num--amber\">04</div><div class=\"wfx-step__title\">Deliver</div><div class=\"wfx-step__text\">Every format you need, source files, full rights.</div></div></div>"
            },
            "elements": []
          }
