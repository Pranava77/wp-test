          {
            "id": "1a2b027",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": {
              "editor": "<p>WEBFIXUS is the one-person illustration studio of an artist who&rsquo;s been making pictures for editorial, games and brands since 2019. No account managers, no hand-offs &mdash; you work directly with the person holding the pen.</p>",
              "drop_cap": "",
