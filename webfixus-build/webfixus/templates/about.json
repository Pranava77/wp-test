          },
          {
            "id": "1a2b028",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": {
              "editor": "<p>I believe illustration should have an opinion. Every brief gets a real idea before it gets a single line, and every line is drawn by hand before it&rsquo;s cleaned up in pixels.</p>",
              "drop_cap": "",
              "_css_classes": "wfx-lead wfx-lead--wide wfx-mt-14"
