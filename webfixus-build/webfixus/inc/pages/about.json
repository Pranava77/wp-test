        "isLinked": false
       }
      }
     },
     {
      "id": "9df2974",
      "elType": "widget",
      "widgetType": "text-editor",
      "settings": {
       "editor": "<p>I believe illustration should have an opinion. Every brief gets a real idea before it gets a single line, and every line is drawn by hand before it's cleaned up in pixels.</p>",
