       "id": "9df2974",
       "elType": "widget",
       "widgetType": "html",
       "settings": {
        "html": "<section class=\"wfx-wrap wfx-pad\" style=\"max-width:1120px;margin:0 auto;padding:40px 32px\">\n  <div style=\"font-family:'Space Mono',monospace;font-size:13px;letter-spacing:.14em;color:#6b6557\">/ HOW I WORK</div>\n  <h2 class=\"wfx-h2\" style=\"font-family:'Archivo',sans-serif;font-weight:900;font-size:40px;letter-spacing:-.02em;margin:10px 0 30px\">FOUR STEPS, NO SURPRISES.</h2>\n  <div class=\"wfx-grid wfx-cols-4\" style=\"gap:20px\"><div style=\"background:#fff;border:3px solid #14110c;box-shadow:6px 6px 0 #14110c;padding:22px\"><div style=\"font-family:'Archivo',sans-serif;font-weight:900;font-size:34px;color:#2b4cff\">01</div><div style=\"font-weight:700;font-size:17px;margin-top:8px\">Brief</div><div style=\"font-size:14px;color:#3a352c;margin-top:6px;line-height:1.45\">We talk. I learn the goal, the audience and the deadline.</div></div><div style=\"background:#fff;border:3px solid #14110c;box-shadow:6px 6px 0 #14110c;padding:22px\"><div style=\"font-family:'Archivo',sans-serif;font-weight:900;font-size:34px;color:#ff5a36\">02</div><div style=\"font-weight:700;font-size:17px;margin-top:8px\">Sketch</div><div style=\"font-size:14px;color:#3a352c;margin-top:6px;line-height:1.45\">2–3 rough directions. We pick one before any polish.</div></div><div style=\"background:#fff;border:3px solid #14110c;box-shadow:6px 6px 0 #14110c;padding:22px\"><div style=\"font-family:'Archivo',sans-serif;font-weight:900;font-size:34px;color:#16a06a\">03</div><div style=\"font-weight:700;font-size:17px;margin-top:8px\">Draw</div><div style=\"font-size:14px;color:#3a352c;margin-top:6px;line-height:1.45\">Final art, hand-drawn, with one round of revisions.</div></div><div style=\"background:#fff;border:3px solid #14110c;box-shadow:6px 6px 0 #14110c;padding:22px\"><div style=\"font-family:'Archivo',sans-serif;font-weight:900;font-size:34px;color:#ffb300\">04</div><div style=\"font-weight:700;font-size:17px;margin-top:8px\">Deliver</div><div style=\"font-size:14px;color:#3a352c;margin-top:6px;line-height:1.45\">Every format you need, source files, full rights.</div></div></div>\n</section>"
