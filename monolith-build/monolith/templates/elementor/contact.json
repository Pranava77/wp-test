graphy_font_size": {"unit": "px", "size": 18, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.55, "sizes": []}, "_margin": {"unit": "px", "top": "22", "right": "0", "bottom": "28", "left": "0", "isLinked": false}}}, {"id": "49cd095", "elType": "widget", "widgetType": "button", "settings": {"text": "hello@example.com", "link": {"url": "mailto:hello@example.com", "is_external": "", "nofollow": "", "custom_attributes": ""}, "button_text_color": "#14110c", "background_color": "#ffffff", "border_border": "solid", "border_width": {"unit": "px", "top": "2", "right": "2", "bottom": "2", "left": "2", "isLinked": false}, "border_color": "#14110c", "text_padding": {"unit": "px", "top": "18", "right": "20", "bottom": "18", "left": "20", "isLinked": false}, "button_box_shadow_box_shadow_type": "yes", "button_box_shadow_box_shadow": {"horizontal": 5, "vertical": 5, "blur": 0, "spread": 0, "color": "#14110c"}, "typography_typography": "custom", "typography_font_family": "Archivo", "typography_font_weight": "800", "typography_font_size": {"unit": "px", "size": 22, "sizes": []}, "align": "left"}}, {"id": "b3e2cec", "elType": "section", "settings": {"gap": "no", "layout": "full_width", "background_background": "classic", "background_color": "#ffd23f", "border_border": "solid", "border_width": {"unit": "px", "top": "3", "right": "3", "bottom": "3", "left": "3", "isLinked": false}, "border_color": "#14110c", "box_shadow_box_shadow_type": "yes", "box_shadow_box_shadow": {"horizontal": 5, "vertical": 5, "blur": 0, "spread": 0, "color": "#14110c"}}, "elements": [{"id": "d5fbe02", "elType": "column", "settings": {"_column_size": 100, "_inline_size": 100, "padding": {"unit": "px", "top": "18", "right": "20", "bottom": "18", "left": "20", "isLinked": false}}, "elements": [{"id": "e6c1558", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<p>AVAILABILITY</p>", "text_color": "#7a6a1f", "align": "left", "typography_typography": "custom", "typography_font_family": "Space Mono", "typography_font_weight": "400", "typography_font_size": {"unit": "px", "size": 12, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.5, "sizes": []}, "typography_letter_spacing": {"unit": "px", "size": 1.2, "sizes": []}, "_margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}}, {"id": "9df2974", "elType": "widget", "widgetType": "heading", "settings": {"title": "Booking from Q3 2026", "header_size": "div", "title_color": "#14110c", "typography_typography": "custom", "typography_font_family": "Archivo", "typography_font_weight": "800", "typography_font_size": {"unit": "px", "size": 22, "sizes": []}, "_margin": {"unit": "px", "top": "4", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}}]}], "isInner": true}, {"id": "a1f84e8", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<span style=\"border-bottom:3px solid #2b4cff;padding-bottom:2px\">INSTAGRAM</span> &nbsp; <span style=\"border-bottom:3px solid #ff5a36;padding-bottom:2px\">BEHANCE</span> &nbsp; <span style=\"border-bottom:3px solid #16a06a;padding-bottom:2px\">DRIBBBLE</span>", "text_color": "#14110c", "align": "left", "typography_typography": "custom", "typography_font_family": "Space Mono", "typography_font_weight": "700", "typography_font_size": {"unit": "px", "size": 13, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.5, "sizes": []}, "typography_letter_spacing": {"unit": "px", "size": 0.78, "sizes": []}, "_margin": {"unit": "px", "top": "16", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}}]}, {"id": "47e8b26", "elType": "column", "settings": {"_column_size": 50, "_inline_size": 50}, "elements": [{"id": "211970d", "elType": "widget", "widgetType": "html", "settings": {"html": "<div id=\"wfx-sent\" style=\"display:none;background:#16a06a;color:#fff;border:3px solid #14110c;box-shadow:8px 8px 0 #14110c;padding:48px 32px;box-sizing:border-box;flex-direction:column;justify-content:center\">\n  <div style=\"font-family:'Archivo',sans-serif;font-weight:900;font-size:40px;line-height:1;letter-spacing:-.02em\">GOT IT! ✊</div>\n  <p style=\"font-size:17px;line-height:1.5;margin:18px 0 0;color:#dffaec\">Thanks for reaching out. We'll get back to you within one business day — usually sooner.</p>\n  <span id=\"wfx-again\" style=\"cursor:pointer;margin-top:26px;display:inline-block;background:#14110c;color:#fff;font-family:'Space Mono',monospace;font-size:13px;font-weight:700;letter-spacing:.06em;padding:12px 18px;border:2px solid #fff;width:fit-content\">SEND ANOTHER →</span>\n</div>\n<form id=\"wfx-form\" style=\"background:#fff;border:3px solid #14110c;box-shadow:8px 8px 0 #14110c;padding:30px\">\n  <label style=\"display:block;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;letter-spacing:.08em;margin-bottom:8px\">NAME</label>\n  <input name=\"name\" required placeholder=\"Your name\" style=\"width:100%;box-sizing:border-box;font-family:'Space Grotesk',sans-serif;font-size:15px;padding:13px 14px;border:2px solid #14110c;background:#f3ede1;outline:none;margin-bottom:18px\" />\n  <label style=\"display:block;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;letter-spacing:.08em;margin-bottom:8px\">EMAIL</label>\n  <input name=\"email\" type=\"email\" required placeholder=\"you@company.com\" style=\"width:100%;box-sizing:border-box;font-family:'Space Grotesk',sans-serif;font-size:15px;padding:13px 14px;border:2px solid #14110c;background:#f3ede1;outline:none;margin-bottom:18px\" />\n  <label style=\"display:block;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;letter-spacing:.08em;margin-bottom:8px\">PROJECT TYPE</label>\n  <select name=\"ptype\" style=\"width:100%;box-sizing:border-box;font-family:'Space Grotesk',sans-serif;font-size:15px;padding:13px 14px;border:2px solid #14110c;background:#f3ede1;outline:none;margin-bottom:18px\">\n    <option>Brand identity</option><option>Website design</option><option>Product design</option><option>Motion</option><option>Something else</option>\n  </select>\n  <label style=\"display:block;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;letter-spacing:.08em;margin-bottom:8px\">THE BRIEF</label>\n  <textarea name=\"brief\" rows=\"4\" placeholder=\"What are we making, and when do you need it?\" style=\"width:100%;box-sizing:border-box;font-family:'Space Grotesk',sans-serif;font-size:15px;padding:13px 14px;border:2px solid #14110c;background:#f3ede1;outline:none;resize:vertical;margin-bottom:22px\"></textarea>\n  <button type=\"submit\" style=\"cursor:pointer;display:block;width:100%;text-align:center;background:#2b4cff;color:#fff;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:16px;padding:15px;border:2px solid #14110c;box-shadow:5px 5px 0 #14110c\">SEND THE BRIEF →</button>\n</form>\n<script>\n(function(){\n  var form=document.getElementById('wfx-form'),sent=document.getElementById('wfx-sent'),again=document.getElementById('wfx-again');\n  if(!form)return;\n  form.addEventListener('submit',function(e){\n    e.preventDefault();var f=form;\n    var subject='New brief: '+(f.ptype.value||'Project')+' — '+(f.name.value||'');\n    var body='Name: '+f.name.value+'\\nEmail: '+f.email.value+'\\nProject type: '+f.ptype.value+'\\n\\n'+f.brief.value;\n    window.location.href='mailto:hello@example.com?subject='+encodeURIComponent(subject)+'&body='+encodeURIComponent(body);\n    form.style.display='none';sent.style.display='flex';\n  });\n  if(again){again.addEventListener('click',function(){sent.style.display='none';form.style.display='block';form.reset();});}\n})();\n</script>"}}]}], "isInner": false}], "page_settings": []}